PORT=5000

# Preferred format (avoids URL-encoding password special characters)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fypDatabase
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# Optional fallback format
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/fypDatabase

JWT_SECRET=replace_with_a_long_random_secret
CORS_ORIGIN=http://localhost:3000

# Forgot password email delivery (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password
SMTP_FROM=Speech Denoiser <your_email@gmail.com>
RESET_TOKEN_EXPIRES_MINUTES=15
